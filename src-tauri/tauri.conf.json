{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ordning",
  "version": "0.6.0",
  "identifier": "com.ordning.app",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ordning",
        "width": 1200,
        "height": 800,
        "minWidth": 1220,
        "minHeight": 645
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
